{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AwsSecrets": {
    "Enabled": true,
    "Region": "us-east-1",
    "SecretId": "/maestro/dev"
  },
  "Kafka": {
    "ServidoresBootstrap": "localhost:9092",
    "IdDeCliente": "maestro-api",
    "GrupoDeConsumidor": "maestro-api",
    "CrearTemasAutomaticamente": true,
    "ParticionesPredeterminadas": 1,
    "FactorDeReplicacionPredeterminado": 1,
    "Enlaces": {
      "criticoRequests-out-0": {
        "Destino": "maestro.critico.requests",
        "TipoDeContenido": "application/json"
      },
      "criticoResponses-in-0": {
        "Destino": "maestro.critico.responses",
        "Grupo": "maestro-api-critico-responses",
        "TipoDeContenido": "application/json"
      },
      "traduccionRequests-out-0": {
        "Destino": "maestro.traduccion.requests",
        "TipoDeContenido": "application/json"
      },
      "traduccionResponses-in-0": {
        "Destino": "maestro.traduccion.responses",
        "Grupo": "maestro-api-traduccion-responses",
        "TipoDeContenido": "application/json"
      }
    }
  },
  "Jwt": {
    "Emisor": "Maestro",
    "Audiencia": "Maestro-Sitio-Web",
    "MinutosDeVida": 15,
    "RefreshDíasDeVida": 30
  }
}
